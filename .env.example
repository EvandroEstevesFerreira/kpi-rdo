# Copie este arquivo para .env.local e preencha com os valores reais
# NUNCA commite o .env.local

# JWT da API do diariodeobra.app — enviado no header `Token`
# Capturar no DevTools do navegador (aba Network -> request headers -> Token)
# ou gerar em web.diariodeobra.app -> Configurações -> API (se disponível)
DIARIO_API_KEY=

# ID da empresa no diariodeobra.app — aparece na URL das chamadas:
# https://api.diariodeobra.app/v2/empresas/<EMPRESA_ID>/obras
# Sistenge: 654a833d61927fcb36089a85
DIARIO_EMPRESA_ID=654a833d61927fcb36089a85

# (Opcional) Sobrescreve a base URL da API. Default: https://api.diariodeobra.app/v2
# DIARIO_API_BASE=https://api.diariodeobra.app/v2

# Forçar dados simulados (true = mock, false = API real)
VITE_USE_MOCK=false

# Autenticação do dashboard (proteção por senha compartilhada)
# Gerar KPI_AUTH_SECRET com: openssl rand -hex 32  (ou qualquer string longa aleatoria)
KPI_AUTH_PASSWORD=
KPI_AUTH_SECRET=
